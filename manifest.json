{
  "manifest_version": 3,
  "name": "Element Hider",
  "version": "1.0",
  "permissions": ["contextMenus", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}